---
interface Props {
  pageUrl: string;
}
const { pageUrl } = Astro.props;
const message = 'Check this free tool on PixMidas:';
const waHref = `https://wa.me/?text=${encodeURIComponent(message + ' ' + pageUrl)}`;
const xHref  = `https://twitter.com/intent/tweet?text=${encodeURIComponent(message)}&url=${encodeURIComponent(pageUrl)}`;
---

<div class="share-wrap">
  <p class="share-heading">This tool is free. Sharing it keeps it that way.</p>
  <p class="share-sub">No subscriptions. No accounts. Just useful tools.</p>
  <div class="share-btns">

    <a href={waHref} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on WhatsApp">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <a href={xHref} target="_blank" rel="noopener noreferrer" class="share-btn" aria-label="Share on X">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.833L2.25 2.25h6.955l4.267 5.643L18.244 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
      </svg>
      X
    </a>

    <button class="share-btn share-copy" type="button" aria-label="Copy link">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/>
      </svg>
      <span>Copy Link</span>
    </button>

  </div>
</div>

<script>
  document.querySelectorAll('.share-copy').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var span = btn.querySelector('span');
      function confirm() {
        span.textContent = 'Copied!';
        btn.classList.add('share-copied');
        setTimeout(function() {
          span.textContent = 'Copy Link';
          btn.classList.remove('share-copied');
        }, 2000);
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(window.location.href).then(confirm).catch(fallback);
      } else {
        fallback();
      }
      function fallback() {
        var ta = document.createElement('textarea');
        ta.value = window.location.href;
        ta.style.cssText = 'position:fixed;opacity:0;pointer-events:none';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); confirm(); } catch(e) {}
        document.body.removeChild(ta);
      }
    });
  });
</script>

<style>
  .share-wrap {
    margin-top: 48px;
    padding-top: 36px;
    border-top: 1px solid var(--border-light);
    text-align: center;
  }

  .share-heading {
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 5px;
  }

  .share-sub {
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 20px;
  }

  .share-btns {
    display: flex;
    gap: 8px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    min-height: 44px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 600;
    font-family: inherit;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    line-height: 1;
  }

  .share-btn:hover {
    background: var(--surface-2);
    color: var(--text);
    border-color: var(--border);
  }

  .share-copied {
    color: var(--success) !important;
    border-color: var(--success-border) !important;
    background: var(--success-bg) !important;
  }

  @media (max-width: 768px) {
    .share-wrap {
      margin-top: 36px;
      padding-top: 28px;
    }

    .share-btn {
      padding: 10px 16px;
      min-height: 44px;
    }
  }
</style>
