    },
    {
      "@type": "Question",
      "name": "What happens to transparency when converting to JPG?",
      "acceptedAnswer": { "@type": "Answer", "text": "JPG does not support transparency. Transparent pixels are filled with white during conversion. If your image needs to remain transparent, convert to PNG or WebP instead — both support full alpha-channel transparency." }
    },
    {
      "@type": "Question",
      "name": "Is there any quality difference between PNG inputs and PNG outputs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Converting between lossless formats is lossless — no quality is lost. Converting lossy JPG to PNG produces a PNG that looks identical to the JPG but cannot recover quality already lost during original JPG encoding." }
    },
    {
      "@type": "Question",
      "name": "What is AVIF and should I use it?",
      "acceptedAnswer": { "@type": "Answer", "text": "AVIF is the newest format offering the best compression — 50% smaller than JPG and 20% smaller than WebP at comparable quality. Supported in Chrome, Firefox, and Safari. Limitation: limited tooling support outside browsers." }
    },
    {
      "@type": "Question",
      "name": "Can I convert multiple images at once?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The converter supports batch uploads — drop multiple files and they are all converted to the same output format. Download individually or all at once. No file count restriction." }
    },
    {
      "@type": "Question",
      "name": "Are my images uploaded to a server?",
      "acceptedAnswer": { "@type": "Answer", "text": "Never. All conversion happens in your browser using the Canvas API. No image file is ever uploaded to any server." }
    }
  ]
}
</script>
