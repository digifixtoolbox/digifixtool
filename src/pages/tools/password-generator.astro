---
import Layout from '../../layouts/Layout.astro';
import PasswordGenerator from '../../components/PasswordGenerator.jsx';
---

<Layout
  title="Free Password Generator Online"
  description="Generate strong, secure passwords instantly. Choose length, uppercase, lowercase, numbers and symbols. Free, no login, runs in your browser."
>
  <div class="tool-page">
    <div class="tool-header">
      <a href="/" class="back-link">← All tools</a>
      <h1 class="tool-title">Password Generator</h1>
      <p class="tool-subtitle">Generate strong, secure passwords instantly. Customize length and character types.</p>
    </div>
    <div class="ad-slot ad-slot-horizontal">Advertisement</div>
    <PasswordGenerator client:load />
    <div class="ad-slot ad-slot-horizontal" style="margin-top: 32px;">Advertisement</div>
    <section class="seo-content">
      <h2>How to generate a secure password</h2>
      <p>Choose your preferred length and character tys, then click Generate. Copy the result and use it immediately.</p>
      <h2>What makes a strong password?</h2>
      <p>A strong password is at least 12 characters long and includes uppercase letters, lowercase letters, numbers and symbols. Avoid using the same password twice.</p>
      <h2>Is this password generator safe?</h2>
      <p>Yes. Everything runs locally in your browser. No passwords are ever sent to any server or stored anywhere.</p>
    </section>
  </div>
</Layout>

<style>
  .tool-page { max-width: 860px; margin: 0 auto; }
  .back-link { font-size: 14px; color: var(--text-muted); font-weight: 500; display: inline-block; margin-bottom: 20px; }
  .tool-header { margin-bottom: 32px; }
  .tool-title { font-size: clamp(28px, 5vw, 48px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 12px; }
  .tool-subtitle { font-size: 16px; color: var(--text-muted); line-height: 1.5; }
  .seo-content { margin-top: 56px; padding-top: 48px; border-top: 1px solid var(--border); }
  .seo-content h2 { font-size: 20px; font-weight: 700; margin-bottom: 10px; margin-top: 32px; }
  .seo-content h2:first-child { margin-top: 0; }
  .seo-content p { color: var(--text-muted); line-height: 1.65; font-size: 15px; }
</style>