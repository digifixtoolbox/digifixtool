  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the output image quality?",
      "acceptedAnswer": { "@type": "Answer", "text": "Pages render at screen resolution (96 DPI equivalent) by default, producing JPGs that look sharp on screen. For print-quality output, a higher scale factor producing 3× the default pixel dimensions would be needed." }
    },
    {
      "@type": "Question",
      "name": "Does this work with password-protected PDFs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Password-protected PDFs require entering the password. If the PDF uses owner-level restrictions (restricting printing/copying but allowing reading), PDF.js may render normally since reading is permitted." }
    },
    {
      "@type": "Question",
      "name": "Does this work with scanned PDFs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Scanned PDFs are image-based and render fine as JPG output. The rendered JPG looks identical to the PDF page view. Use the OCR tool on output images to extract text from scanned pages." }
    },
    {
      "@type": "Question",
      "name": "Can I convert only specific pages?",
      "acceptedAnswer": { "@type": "Answer", "text": "All pages render first and appear as thumbnails. Download only the pages you need by clicking individual Download buttons rather than Download All. Pre-filtering pages before rendering is not available." }
    },
    {
      "@type": "Question",
      "name": "Why are some PDFs slow to convert?",
      "acceptedAnswer": { "@type": "Answer", "text": "Rendering speed depends on page count, complexity, and embedded assets. PDFs with many high-resolution images, complex vectors, or many fonts take longer per page. Very large PDFs may take a minute or more but the browser tab stays responsive." }
    },
    {
      "@type": "Question",
      "name": "Are my PDFs uploaded to a server?",
      "acceptedAnswer": { "@type": "Answer", "text": "Never. PDF rendering uses PDF.js in your browser. Your PDF is never uploaded to any server — important for confidential reports, legal documents, and personal records." }
    }
  ]
}
</script>
