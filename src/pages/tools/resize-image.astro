      "acceptedAnswer": { "@type": "Answer", "text": "No enforced limit. Very large images above 20 megapixels may take a moment to process. The limiting factor is your browser's available memory, not a server-side restriction." }
    },
    {
      "@type": "Question",
      "name": "Can I resize to exact social media dimensions?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Common targets include 1200x630 for Open Graph images, 1080x1080 for Instagram posts, 1080x1920 for Stories, and 1500x500 for Twitter headers. Check the social media sizes reference tool for a complete list." }
