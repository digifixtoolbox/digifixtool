  "@type": "WebApplication",
  "name": "Image Cropper",
  "url": "https://www.pixmidas.com/tools/image-cropper/",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "browserRequirements": "Requires JavaScript",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Crop images to any size or aspect ratio. Set exact dimensions or drag to select. Free, private, runs in your browser.",
  "provider": { "@type": "Organization", "name": "PixMidas", "url": "https://www.pixmidas.com" }
}
</script>

