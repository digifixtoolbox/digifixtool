  "name": "SVG to PNG Converter",
  "url": "https://www.pixmidas.com/tools/svg-to-png/",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any",
  "browserRequirements": "Requires JavaScript",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Convert SVG files to PNG at any resolution. Set custom dimensions and export with or without transparency. Free, private, runs in your browser.",
  "provider": { "@type": "Organization", "name": "PixMidas", "url": "https://www.pixmidas.com" }
}
</script>

