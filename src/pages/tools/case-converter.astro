---
import Layout from '../../layouts/Layout.astro';
import CaseConverter from '../../components/CaseConverter.jsx';
---

<Layout
  title="Case Converter Online Free"
  description="Convert text to uppercase, lowercase, title case, sentence case, camelCase, snake_case and kebab-case instantly. Free, no login required."
>
  <div class="tool-page">
    <div class="tool-header">
      <a href="/" class="back-link">← All tools</a>
      <h1 class="tool-title">Case Converter</h1>
      <p class="tool-subtitle">Convert text to any case instantly. Uppercase, lowercase, title case, camelCase and more.</p>
    </div>
    <div class="ad-slot ad-slot-horizontal">Advertisement</div>
    <CaseConverter client:load />
    <div class="ad-slot ad-slot-horizontal" style="margin-top: 32px;">Advertisement</div>
    <section class="seo-content">
      <h2>What is a case converter?</h2>
      <p>A case converter changes the capitalization of your text. Useful for devopers, writers and designers.</p>
      <h2>What cases are supported?</h2>
      <p>UPPERCASE, lowercase, Title Case, Sentence case, camelCase, snake_case and kebab-case.</p>
      <h2>Is my text stored?</h2>
      <p>No. Everything runs locally in your browser. Your text is never sent to any server.</p>
    </section>
  </div>
</Layout>

<style>
  .tool-page { max-width: 860px; margin: 0 auto; }
  .back-link { font-size: 14px; color: var(--text-muted); font-weight: 500; display: inline-block; margin-bottom: 20px; }
  .tool-header { margin-bottom: 32px; }
  .tool-title { font-size: clamp(28px, 5vw, 48px); font-weight: 800; letter-spacing: -0.03em; margin-bottom: 12px; }
  .tool-subtitle { font-size: 16px; color: var(--text-muted); line-height: 1.5; }
  .seo-content { margin-top: 56px; padding-top: 48px; border-top: 1px solid var(--border); }
  .seo-content h2 { font-size: 20px; font-weight: 700; margin-bottom: 10px; margin-top: 32px; }
  .seo-content h2:first-child { margin-top: 0; }
  .seo-content p { color: var(--text-muted); line-height: 1.65; font-size: 15px; }
</style>