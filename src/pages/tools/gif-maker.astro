          <a href="/tools/compress-image/">Compress Image</a>
          <a href="/tools/convert-image/">Convert Image</a>
          <a href="/tools/social-sizes/">Social Media Sizes</a>
        </div>
      </div>
    </section>

    <RelatedTools slugs={["resize-image", "compress-image", "convert-image"]} />
  </div>
</Layout>

