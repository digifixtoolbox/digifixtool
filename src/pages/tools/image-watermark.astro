      "acceptedAnswer": { "@type": "Answer", "text": "The tool processes one image at a time. For batch watermarking many images with identical settings, use Photoshop Batch Actions or GIMP with Script-Fu for automated bulk operations." }
    },
    {
      "@type": "Question",
      "name": "Are my photos uploaded to a server?",
      "acceptedAnswer": { "@type": "Answer", "text": "Never. Watermark compositing uses the browser's Canvas API. Your photos are never uploaded to any server, important for unreleased work, personal photos, and confidential client images." }
    }
  ]
