<script>
  (function () {
    var title = document.querySelector('.hero-title');
    function adjustHeadlineSize() {
      if (!title) return;
      title.style.fontSize = '';
      var lineHeight = parseFloat(getComputedStyle(title).lineHeight);
      var lines = Math.round(title.offsetHeight / lineHeight);
      if (lines > 2) {
        var size = parseFloat(getComputedStyle(title).fontSize);
        while (size > 28) {
          size -= 1;
          title.style.fontSize = size + 'px';
          if (Math.round(title.offsetHeight / lineHeight) <= 2) break;
        }
      }
    }
    adjustHeadlineSize();
    window.addEventListener('resize', adjustHeadlineSize);
  }());
</script>

