---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.jsx';

const tools = [
  { slug: 'compress-image', name: 'Image Compressor', description: 'Make image files smaller without losing quality.', icon: String.fromCodePoint(0x1F5DC)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: true },
  { slug: 'resize-image', name: 'Image Resizer', description: 'Resize photos to exact pixel dimensions.', icon: String.fromCodePoint(0x1F4D0), bg: '#e8f4fd', category: 'Image', popular: true },
  { slug: 'image-cropper', name: 'Image Cropper', description: 'Crop any image instantly. Draw a selection and download.', icon: String.fromCodePoint(0x2702)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false },
  { slug: 'convert-image', name: 'Image Converter', description: 'Convert PNG to JPG or JPG to PNG in one click.', icon: String.fromCodePoint(0x1F504), bg: '#e8f4fd', category: 'Image', popular: false },
  { slug: 'image-info', name: 'Image Info', description: 'Check the size, format and dimensions of any image.', icon: String.fromCodePoint(0x1F50D), bg: '#e8f4fd', category: 'Image', popular: false },
  { slug: 'webp-to-jpg', name: 'WebP to JPG', description: 'Convert WebP images to JPG instantly. Multiple files supported.', icon: String.fromCodePoint(0x1F5BC)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false },
  { slug: 'exif-remover', name: 'EXIF Data Remover', description: 'Strip hidden GPS, device info and timestamps from photos.', icon: String.fromCodePoint(0x1F6E1)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false },
  { slug: 'social-sizes', name: 'Social Media Sizes', description: 'Find the correct image size for every social platform.', icon: String.fromCodePoint(0x1F4F1), bg: '#f0e8fd', category: 'Social', popular: false },
  { slug: 'images-to-pdf', name: 'Images to PDF', description: 'Combine multiple photos into one PDF document.', icon: String.fromCodePoint(0x1F4C4), bg: '#fef3e8', category: 'PDF', popular: false },
  { slug: 'pdf-to-jpg', name: 'PDF to JPG', description: 'Convert every PDF page to a JPG image instantly.', icon: String.fromCodePoint(0x1F4F8), bg: '#fef3e8', category: 'PDF', popular: false },
  { slug: 'merge-pdfs', name: 'Merge PDFs', description: 'Combine multiple PDF files into one document.', icon: String.fromCodePoint(0x1F4D1), bg: '#fef3e8', category: 'PDF', popular: false },
  { slug: 'word-count', name: 'Word Counter', description: 'Count words, characters and paragraphs instantly.', icon: String.fromCodePoint(0x1F4DD), bg: '#e8fdf0', category: 'Text', popular: false },
  { slug: 'case-converter', name: 'Case Converter', description: 'Convert text to uppercase, lowercase, title case and more.', icon: String.fromCodePoint(0x1F521), bg: '#e8fdf0', category: 'Text', popular: false },
  { slug: 'text-diff', name: 'Text Difference Checker', description: 'Compare two texts and see exactly what changed.', icon: String.fromCodePoint(0x1F50E), bg: '#e8fdf0', category: 'Text', popular: false },
  { slug: 'lorem-ipsum', name: 'Lorem Ipsum Generator', description: 'Generate placeholder text for layouts and mockups.', icon: String.fromCodePoint(0x1F4C3), bg: '#e8fdf0', category: 'Text', popular: false },
  { slug: 'json-formatter', name: 'JSON Formatter', description: 'Format, validate and minify JSON data instantly.', icon: String.fromCodePoint(0x1F4CB), bg: '#e8fdf0', category: 'Utility', popular: false },
  { slug: 'qr-code', name: 'QR Code Generator', description: 'Create QR codes for any link, text or phone number.', icon: String.fromCodePoint(0x1F533), bg: '#fdf0e8', category: 'Utility', popular: false },
  { slug: 'password-generator', name: 'Password Generator', description: 'Generate strong, secure passwords instantly.', icon: String.fromCodePoint(0x1F510), bg: '#e8fdf0', category: 'Utility', popular: false },
  { slug: 'color-picker', name: 'Color Picker', description: 'Pick any color and get HEX, RGB and HSL values.', icon: String.fromCodePoint(0x1F3A8), bg: '#fef3e8', category: 'Utility', popular: false },
  { slug: 'base64', name: 'Base64 Encoder / Decoder', description: 'Encode text to Base64 or decode Base64 strings instantly.', icon: String.fromCodePoint(0x1F4BB), bg: '#e8fdf0', category: 'Utility', popular: false },
];

const categories = ['All', 'Image', 'PDF', 'Text', 'Utility', 'Social'];
---

<Layout
  title="Free Online Tools – Fast, Private & No Login Required"
  description="Free browser-based tools for images, text, PDFs and more. Compress images, resize photos, generate QR codes, count words and much more. No login, no upload, runs in your browser."
>
  <section class="hero">
    <h1 class="hero-title">Free tools<br/>that just work.</h1>
    <p class="hero-sub">No login. No confusion. Fast browser tools for everyday digital tasks.</p>

    <div class="quick-links">
      <a href="/tools/compress-image/">Compress Image</a>
      <span>·</span>
      <a href="/tools/resize-image/">Resize Image</a>
      <span>·</span>
      <a href="/tools/qr-code/">QR Code Generator</a>
    </div>

    <a href="#all-tools" class="hero-btn">See all tools ↓</a>
  </section>

  <div class="promo-wrap">
    <PromoBanner client:load />
  </div>

  <section id="all-tools" class="tools-section">
    <div class="filter-bar-wrap">
      <div class="filter-bar">
        {categories.map((cat) => (
          <button class="filter-btn" data-category={cat} aria-pressed={cat === 'All' ? 'true' : 'false'}>
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div class="search-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.6"/>
        <path d="M11.5 11.5L15.5 15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        id="tool-search"
        class="search-input"
        placeholder="Search tools… (e.g. compress, PDF, QR)"
        aria-label="Search tools"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-kbd" aria-hidden="true">/</span>
    </div>

    <div class="tools-grid">
      {tools.map((tool) => (
        <a
          class="tool-card"
          href={"/tools/" + tool.slug + "/"}
          data-category={tool.category}
          data-search={(tool.name + ' ' + tool.description + ' ' + tool.category).toLowerCase()}
        >
          <div class="tool-icon-wrap" data-bg={tool.bg}>
            <span class="tool-icon">{tool.icon}</span>
          </div>
          <div class="tool-body">
            <div class="tool-name-row">
              <h3 class="tool-name">{tool.name}</h3>
              {tool.popular && <span class="badge">Popular</span>}
            </div>
            <p class="tool-desc">{tool.description}</p>
          </div>
          <span class="tool-arrow">→</span>
        </a>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display:none">
      No tools found for that. Try something else.
    </p>
  </section>

  <!-- Rest of the sections (Trust, SEO, etc.) -->
  <section class="trust-section">
    <div class="trust-grid">
      <div class="trust-item">
        <span class="trust-icon">🔒</span>
        <div>
          <strong>Private by design</strong>
          <p>Many tools run locally in your browser. Your files stay on your device.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⚡</span>
        <div>
          <strong>Fast and simple</strong>
          <p>No heavy software or confusing steps. Results in seconds.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🆓</span>
        <div>
          <strong>Always free</strong>
          <p>No account needed. No payment. No hidden limits.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Script logic for filtering
  document.querySelectorAll('.tool-icon-wrap').forEach(function(wrap) {
    var bg = wrap.getAttribute('data-bg');
    wrap.style.background = bg;
  });

  var searchInput = document.getElementById('tool-search');
  var buttons = document.querySelectorAll('.filter-btn');
  var cards = document.querySelectorAll('.tool-card');
  var noResults = document.getElementById('no-results');
  var activeCategory = 'All';

  function filterTools() {
    var query = searchInput.value.toLowerCase().trim();
    var visible = 0;
    cards.forEach(function(card) {
      var catMatch = activeCategory === 'All' || card.getAttribute('data-category') === activeCategory;
      var searchMatch = !query || (card.getAttribute('data-search') || '').includes(query);
      var show = catMatch && searchMatch;
      card.style.display = show ? 'flex' : 'none';
      if (show) visible++;
    });
    noResults.style.display = visible === 0 ? 'block' : 'none';
  }

  buttons.forEach(function(btn) {
    btn.addEventListener('click', function() {
      activeCategory = btn.getAttribute('data-category');
      buttons.forEach(function(b) { b.setAttribute('aria-pressed', 'false'); });
      btn.setAttribute('aria-pressed', 'true');
      filterTools();
    });
  });

  searchInput.addEventListener('input', filterTools);
</script>

<style>
  /* Styles as before */
  .filter-bar-wrap { overflow-x: auto; margin-bottom: 12px; }
  .filter-bar { display: flex; gap: 8px; width: max-content; padding-bottom: 4px; }
  .filter-btn { padding: 10px 20px; border-radius: 999px; border: 1px solid var(--border); background: var(--surface-2); font-weight: 600; cursor: pointer; }
  .filter-btn[aria-pressed="true"] { background: var(--accent); color: white; border-color: var(--accent); }
  /* ... etc */
</style>