---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.jsx';
import ShareSection from '../components/ShareSection.astro';
import ToolIcon from '../components/ToolIcon.jsx';

const tools = [
  // ── Image ──────────────────────────────────────────────────────────────────
  { slug: 'compress-image', name: 'Image Compressor', description: 'Make image files smaller without losing quality.', iconClass: 'file-zip', iconPalette: 'purple', category: 'Image', popular: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'jpg', 'jpeg', 'png', 'webp', 'shrink', 'reduce', 'optimize', 'optimise', 'smaller', 'file size', 'upload', 'lighter', 'web', 'website speed', 'loading', 'performance', 'reduce size', 'make smaller'] },
  { slug: 'resize-image', name: 'Image Resizer', description: 'Resize photos to exact pixel dimensions.', iconClass: 'resize', iconPalette: 'blue', category: 'Image', popular: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'scale', 'dimensions', 'width', 'height', 'pixels', 'resolution', 'thumbnail', 'rescale', 'stretch', 'change size', 'make bigger', 'make smaller', 'fit', 'custom size'] },
  { slug: 'heic-to-jpg', name: 'HEIC to JPG', description: 'Convert iPhone photos to JPG instantly.', iconClass: 'refresh', iconPalette: 'blue', category: 'Image', popular: true, tags: ['apple', 'iphone', 'heic', 'heif', 'convert', 'photo', 'ios', 'compatibility', 'windows', 'open heic'] },
  { slug: 'background-remover', name: 'Background Remover', description: 'Remove the background from any image instantly using AI.', iconClass: 'wand', iconPalette: 'coral', category: 'Image', popular: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'background', 'remove background', 'transparent', 'png', 'cutout', 'erase background', 'photo editing', 'ai', 'artificial intelligence', 'subject', 'portrait', 'product photo', 'studio', 'white background', 'silhouette', 'transparency'] },
  { slug: 'image-cropper', name: 'Image Cropper', description: 'Crop any image instantly. Draw a selection and download.', iconClass: 'crop', iconPalette: 'green', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'photo editing', 'trim', 'cut', 'frame', 'aspect ratio', 'portrait', 'landscape', 'square', 'selection', 'clip', 'cut out', 'remove border'] },
  { slug: 'convert-image', name: 'Image Converter', description: 'Convert PNG to JPG or JPG to PNG in one click.', iconClass: 'arrows-exchange', iconPalette: 'blue', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'format', 'jpg', 'jpeg', 'png', 'webp', 'gif', 'bmp', 'tiff', 'change format', 'transform', 'export', 'save as', 'file format'] },
  { slug: 'webp-to-jpg', name: 'WebP to JPG', description: 'Convert WebP images to JPG instantly. Multiple files supported.', iconClass: 'photo', iconPalette: 'blue', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'format', 'convert', 'webp converter', 'compatibility', 'apple', 'ios', 'safari', 'chrome', 'browser', 'batch', 'multiple files'] },
  { slug: 'passport-photo-maker', name: 'Passport Photo Maker', description: 'Create official passport photos for any country.', iconClass: 'id', iconPalette: 'amber', category: 'Image', newTool: true, tags: ['passport', 'visa', 'id photo', 'biometric', 'background removal', 'face', 'portrait', 'crop', 'official', 'print photo'] },
  { slug: 'exif-remover', name: 'EXIF Data Remover', description: 'Strip hidden GPS, device info and timestamps from photos.', iconClass: 'shield-off', iconPalette: 'green', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'metadata', 'privacy', 'gps', 'location', 'coordinates', 'strip', 'clean', 'anonymous', 'secure', 'camera data', 'personal data', 'geolocation', 'remove metadata', 'sharing safely'] },
  { slug: 'image-info', name: 'Image Info', description: 'Check the size, format and dimensions of any image.', iconClass: 'info-circle', iconPalette: 'purple', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'metadata', 'details', 'dimensions', 'resolution', 'megapixel', 'aspect ratio', 'file type', 'properties', 'inspect', 'dpi', 'camera info', 'check image', 'view details'] },
  { slug: 'image-to-text', name: 'Image to Text (OCR)', description: 'Extract text from photos, screenshots and scanned documents.', iconClass: 'scan', iconPalette: 'coral', category: 'Image', newTool: true, tags: ['photo', 'foto', 'picture', 'photography', 'ocr', 'optical character recognition', 'text recognition', 'scan', 'screenshot', 'document', 'extract text', 'read text', 'copy text', 'tesseract', 'image text', 'text from image', 'scanned', 'handwriting'] },
  { slug: 'gif-maker', name: 'GIF Maker', description: 'Create animated GIFs from a sequence of images.', iconClass: 'player-play', iconPalette: 'blue', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'animation', 'animated', 'gif', 'frames', 'slideshow', 'loop', 'create gif', 'make gif', 'gif creator', 'meme', 'social media', 'sticker', 'motion', 'sequence'] },
  { slug: 'image-watermark', name: 'Image Watermark', description: 'Add a custom text watermark to any photo or image.', iconClass: 'writing', iconPalette: 'purple', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'watermark', 'copyright', 'text overlay', 'brand', 'protect', 'logo', 'stamp', 'mark', 'signature', 'ownership', 'creator', 'protect image'] },
  { slug: 'color-palette', name: 'Color Palette Generator', description: 'Extract the dominant colors from any image instantly.', iconClass: 'palette', iconPalette: 'pink', category: 'Image', newTool: true, tags: ['photo', 'foto', 'picture', 'photography', 'color', 'colour', 'palette', 'extract colors', 'dominant colors', 'hex', 'rgb', 'design', 'branding', 'web design', 'color scheme', 'colour scheme', 'swatches', 'color picker', 'brand colors'] },
  { slug: 'svg-to-png', name: 'SVG to PNG', description: 'Convert SVG vector files to high-resolution PNG images.', iconClass: 'vector', iconPalette: 'blue', category: 'Image', newTool: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'svg', 'vector', 'convert', 'raster', 'png', 'export', 'icon', 'logo', 'illustration', 'format', 'resolution', 'web design', 'graphics'] },
  { slug: 'favicon-generator', name: 'Favicon Generator', description: 'Generate favicon PNG files in all sizes for your website.', iconClass: 'browser', iconPalette: 'green', category: 'Image', tags: ['photo', 'foto', 'picture', 'photography', 'web design', 'favicon', 'icon', 'website icon', 'browser icon', 'tab icon', 'pwa', 'apple touch icon', 'android icon', 'manifest', 'web app', 'logo', '16x16', '32x32', '512x512', 'zip', 'download'] },
  // ── PDF ────────────────────────────────────────────────────────────────────
  { slug: 'compress-pdf', name: 'PDF Compressor', description: 'Shrink PDF file size while maintaining quality.', iconClass: 'file-minus', iconPalette: 'coral', category: 'PDF', popular: true, tags: ['document', 'shrink', 'reduce size', 'optimize pdf', 'smaller pdf', 'email attachment', 'optimize', 'files', 'pdf tools'] },
  { slug: 'merge-pdfs', name: 'Merge PDFs', description: 'Combine multiple PDF files into one document.', iconClass: 'files', iconPalette: 'coral', category: 'PDF', popular: true, tags: ['document', 'combine', 'join', 'concatenate', 'files', 'pages', 'stitch', 'creation', 'merge files', 'report', 'presentation', 'paperwork', 'combine documents'] },
  { slug: 'pdf-to-jpg', name: 'PDF to JPG', description: 'Convert every PDF page to a JPG image instantly.', iconClass: 'file-export', iconPalette: 'coral', category: 'PDF', tags: ['document', 'pages', 'extract', 'photo', 'picture', 'scan', 'view', 'render', 'creation', 'presentation', 'slide', 'export image', 'screenshot', 'page to image'] },
  { slug: 'images-to-pdf', name: 'Images to PDF', description: 'Combine multiple photos into one PDF document.', iconClass: 'file-import', iconPalette: 'coral', category: 'PDF', tags: ['photo', 'foto', 'picture', 'photography', 'creation', 'jpg', 'jpeg', 'png', 'combine', 'merge', 'create document', 'scans', 'album', 'portfolio', 'presentation', 'print', 'pages', 'book'] },
  // ── Text ───────────────────────────────────────────────────────────────────
  { slug: 'word-count', name: 'Word Counter', description: 'Count words, characters and paragraphs instantly.', iconClass: '123', iconPalette: 'green', category: 'Text', popular: true, tags: ['writing', 'editing', 'article', 'essay', 'blog', 'letter', 'character count', 'reading time', 'sentences', 'paragraphs', 'typing', 'content', 'seo', 'word limit', 'copywriting', 'script', 'story', 'document'] },
  { slug: 'lorem-ipsum', name: 'Lorem Ipsum Generator', description: 'Generate placeholder text for layouts and mockups.', iconClass: 'text-size', iconPalette: 'green', category: 'Text', tags: ['editing', 'writing', 'creation', 'design', 'web design', 'placeholder', 'dummy text', 'filler', 'mockup', 'sample', 'prototype', 'fake text', 'latin', 'ipsum', 'ui design', 'wireframe', 'template', 'content', 'paragraph generator'] },
  { slug: 'case-converter', name: 'Case Converter', description: 'Convert text to uppercase, lowercase, title case and more.', iconClass: 'letter-case', iconPalette: 'green', category: 'Text', tags: ['editing', 'writing', 'uppercase', 'lowercase', 'title case', 'camelcase', 'snake_case', 'kebab-case', 'capitalize', 'sentence case', 'programming', 'transform', 'formatting', 'fix caps', 'coding', 'change case'] },
  { slug: 'text-diff', name: 'Text Difference Checker', description: 'Compare two texts and see exactly what changed.', iconClass: 'file-diff', iconPalette: 'green', category: 'Text', newTool: true, tags: ['editing', 'writing', 'compare', 'difference', 'delta', 'changes', 'version', 'before after', 'diff', 'code review', 'track changes', 'duplicate', 'programming', 'git', 'revision', 'find changes', 'document comparison'] },
  // ── Developer ──────────────────────────────────────────────────────────────
  { slug: 'json-formatter', name: 'JSON Formatter', description: 'Format, validate and minify JSON data instantly.', iconClass: 'code', iconPalette: 'amber', category: 'Developer', tags: ['developer', 'web', 'internet', 'online', 'programming', 'code', 'api', 'data', 'pretty print', 'validate', 'minify', 'syntax', 'javascript', 'object', 'lint', 'parse', 'backend', 'frontend', 'rest api', 'debugging', 'format code'] },
  { slug: 'base64', name: 'Base64 Encoder / Decoder', description: 'Encode text to Base64 or decode Base64 strings instantly.', iconClass: 'lock', iconPalette: 'amber', category: 'Developer', tags: ['developer', 'web', 'internet', 'online', 'programming', 'encode', 'decode', 'encoding', 'binary', 'string', 'data uri', 'api', 'cipher', 'obfuscate', 'web development', 'email', 'url safe', 'image embedding', 'encryption'] },
  // ── Social ─────────────────────────────────────────────────────────────────
  { slug: 'social-sizes', name: 'Social Media Sizes', description: 'Find the correct image size for every social platform.', iconClass: 'device-mobile', iconPalette: 'purple', category: 'Social', newTool: true, tags: ['internet', 'web', 'online', 'network', 'media', 'photo', 'foto', 'picture', 'photography', 'design', 'creation', 'instagram', 'facebook', 'twitter', 'x', 'youtube', 'tiktok', 'linkedin', 'pinterest', 'snapchat', 'reddit', 'banner', 'cover photo', 'profile picture', 'post', 'social media', 'dimensions', 'thumbnail', 'story', 'reel', 'header', 'marketing', 'content creator', 'influencer', 'digital marketing', 'ads'] },
  // ── Utility ────────────────────────────────────────────────────────────────
  { slug: 'qr-code', name: 'QR Code Generator', description: 'Create QR codes for any link, text or phone number.', iconClass: 'qrcode', iconPalette: 'purple', category: 'Utility', popular: true, tags: ['internet', 'web', 'online', 'network', 'creation', 'link', 'url', 'scan', 'barcode', 'mobile', 'phone', 'camera', 'wifi', 'contact', 'vcard', 'share', 'digital', 'contactless', 'payment', 'restaurant menu', 'event', 'marketing', 'print', 'poster', 'business card'] },
  { slug: 'color-picker', name: 'Color Picker', description: 'Pick any color and get HEX, RGB and HSL values.', iconClass: 'color-picker', iconPalette: 'pink', category: 'Utility', tags: ['internet', 'web', 'online', 'editing', 'creation', 'media', 'design', 'colour', 'colour picker', 'hex', 'rgb', 'hsl', 'cmyk', 'palette', 'brand', 'css', 'web design', 'graphics', 'shade', 'tint', 'art', 'ui', 'ux', 'branding', 'logo', 'color scheme', 'colour scheme', 'color code', 'colour code', 'website color', 'marketing'] },
  { slug: 'password-generator', name: 'Password Generator', description: 'Generate strong, secure passwords instantly.', iconClass: 'key', iconPalette: 'amber', category: 'Utility', popular: true, tags: ['internet', 'web', 'online', 'network', 'security', 'random', 'strong password', 'secure', 'credentials', 'login', 'account', 'passphrase', 'secret', 'cybersecurity', 'safe', 'protection', 'authentication', 'privacy', 'pin', 'encryption', 'hack proof'] },
];

const categories = ['All', 'Image', 'PDF', 'Text', 'Social', 'Developer', 'Utility'];

const paletteColors = {
  purple: '#5746AF',
  blue:   '#1A6EBF',
  coral:  '#C44B20',
  green:  '#0D7A5A',
  amber:  '#A06010',
  pink:   '#A0306A',
};
---

<Layout
  title="PixMidas: Free Online Tools for Images, PDFs and Text"
  description="30+ free tools for images, PDFs, text and utilities. No installs, no signup, no uploads. Everything runs privately in your browser."
>
  <section class="hero">
    <h1 class="hero-title hero-headline">Free tools<br/>that just work.</h1>
    <script is:inline>
      (function () {
        var h = [
          "Free tools<br>that just work.",
          "The Midas touch<br>for your files.",
          "Sharp tools.<br>Zero cost.",
          "Less software.<br>More done!",
          "30 tools.<br>One browser tab.",
          "Gluten free.<br>Tool rich!"
        ];
        var el = document.querySelector('.hero-headline');
        if (el) el.innerHTML = h[Math.floor(Math.random() * h.length)];
      }());
    </script>
    <p class="hero-sub">Images, PDFs, text, utilities and more.</p>
    <p class="hero-privacy">🔒 Privacy-focused tools that run in your browser.</p>
    <div class="hero-cta">
      <a href="#all-tools" class="hero-btn-primary">Browse all tools ↓</a>
      <a href="/tools/compress-image/" id="hero-try-btn" class="hero-btn-secondary">Try Image Compressor →</a>
    </div>
    <p class="hero-trust">No account · No watermarks · Works on any device</p>
    <div class="pwa-wrap">
      <div id="pwa-overlay" class="pwa-overlay" style="display:none"></div>
      <div id="pwa-popup" class="pwa-popup" style="display:none">
        <button id="pwa-popup-close" class="pwa-popup-close" aria-label="Close">✕</button>
        <p class="pwa-popup-title" id="pwa-popup-title"></p>
        <p class="pwa-popup-subtitle" id="pwa-popup-subtitle"></p>
        <hr class="pwa-popup-divider">
        <ol class="pwa-popup-steps" id="pwa-popup-steps"></ol>
        <hr class="pwa-popup-divider">
        <p class="pwa-popup-footer">Free · No download · No App Store needed</p>
      </div>
      <div class="pwa-link-row">
        <button id="pwa-install-btn" style="display:none" class="pwa-install-btn">📲 Add to your home screen</button>
        <button id="pwa-dismiss-btn" style="display:none" class="pwa-dismiss-btn" aria-label="Dismiss">✕</button>
      </div>
    </div>
  </section>

  <div class="promo-wrap">
    <PromoBanner client:load />
  </div>

  <section id="all-tools" class="tools-section">
    <div class="filter-bar-wrap">
      <div class="filter-bar">
        <button class="filter-btn" data-category="All" aria-pressed="true">All</button>
        <button class="filter-btn filter-btn-new" data-category="New" aria-pressed="false">New</button>
        <button class="filter-btn filter-btn-popular" data-category="Popular" aria-pressed="false">Popular</button>
        <button class="filter-btn" data-category="Image" aria-pressed="false">Image</button>
        <button class="filter-btn" data-category="PDF" aria-pressed="false">PDF</button>
        <button class="filter-btn" data-category="Text" aria-pressed="false">Text</button>
        <button class="filter-btn" data-category="Social" aria-pressed="false">Social</button>
        <button class="filter-btn" data-category="Developer" aria-pressed="false">Code</button>
        <button class="filter-btn" data-category="Utility" aria-pressed="false">Tools</button>
      </div>
    </div>

    <div class="search-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.6"/>
        <path d="M11.5 11.5L15.5 15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        id="tool-search"
        class="search-input"
        placeholder="Search tools… (e.g. compress, PDF, QR)"
        aria-label="Search tools"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-kbd" aria-hidden="true">/</span>
    </div>

    <div class="tools-grid">
      {tools.map((tool) => (
        <a
          class="tool-card"
          href={"/tools/" + tool.slug + "/"}
          data-category={tool.category}
          data-popular={tool.popular ? 'true' : 'false'}
          data-new={tool.newTool ? 'true' : 'false'}
          data-search={(tool.name + ' ' + tool.description + ' ' + tool.category + ' ' + tool.tags.join(' ')).toLowerCase()}
        >
          <div class="tool-icon-wrap" data-icon-palette={tool.iconPalette}>
            <ToolIcon name={tool.iconClass} size={38} color={paletteColors[tool.iconPalette] || 'currentColor'} stroke={1.75} />
          </div>
          <div class="tool-text">
            <h3 class="tool-name">{tool.name}</h3>
            <p class="tool-desc">{tool.description}</p>
          </div>
          <span class="tool-arrow">→</span>
        </a>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display:none">
      No tools found for that. Try something else.
    </p>
  </section>

  <div class="promo-wrap promo-bottom">
    <PromoBanner client:load />
  </div>

  <section class="trust-section">
    <div class="trust-grid">
      <div class="trust-item">
        <span class="trust-icon">🔒</span>
        <div>
          <strong>Private by design</strong>
          <p>Many tools run locally in your browser. Your files stay on your device.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⚡</span>
        <div>
          <strong>Fast and simple</strong>
          <p>No heavy software or confusing steps. Results in seconds.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🆓</span>
        <div>
          <strong>Always free</strong>
          <p>No account needed. No payment. No hidden limits.</p>
        </div>
      </div>
    </div>
  </section>

  <ShareSection pageUrl="https://www.pixmidas.com/" />

  <section class="seo-content">
    <h2>Free Online Tools for Images, Text, PDFs and More</h2>
    <p>PixMidas is a growing collection of free browser-based tools built for everyday digital tasks. Compress and resize images, convert between formats, generate QR codes, count words, merge PDFs, pick colors, compare text differences and more, all without installing software, creating an account or uploading your files to a server.</p>
    <p>Privacy is a first principle here. Most tools process your files entirely on your device using browser APIs. Your images, documents and text stay on your machine. Nothing is transmitted, logged or stored. Fast, simple and private by design.</p>
    <h3>Image Tools</h3>
    <p>Compress JPG, PNG and WebP images to reduce file size without visible quality loss. Resize photos to exact pixel dimensions. Crop images by drawing a selection. Convert between PNG, JPG and WebP formats. Check image dimensions and file size. Convert WebP images to JPG for maximum compatibility.</p>
    <h3>PDF Tools</h3>
    <p>Convert PDF pages to JPG images. Combine multiple images into a single PDF. Merge several PDF files into one document. All PDF processing runs in the browser. No cloud upload required.</p>
    <h3>Text Tools</h3>
    <p>Count words, characters and sentences in real time. Convert text between uppercase, lowercase, title case, camelCase, snake_case and kebab-case. Compare two texts side by side and highlight every difference. Generate lorem ipsum placeholder text for layouts and mockups.</p>
    <h3>Developer Tools</h3>
    <p>Format and validate JSON data. Encode text to Base64 or decode Base64 strings. Generate QR codes for any URL, text, email or phone number. Create strong random passwords. Pick colors and get HEX, RGB and HSL codes.</p>
    <h3>All Free Tools on PixMidas</h3>
    <ul class="seo-list" style="display:grid; grid-template-columns:1fr 1fr; gap:4px 40px;">
      <li><a href="/tools/compress-image/">Image Compressor</a></li>
      <li><a href="/tools/resize-image/">Image Resizer</a></li>
      <li><a href="/tools/heic-to-jpg/">HEIC to JPG Converter</a></li>
      <li><a href="/tools/background-remover/">Background Remover</a></li>
      <li><a href="/tools/image-cropper/">Image Cropper</a></li>
      <li><a href="/tools/convert-image/">PNG to JPG Converter</a></li>
      <li><a href="/tools/webp-to-jpg/">WebP to JPG Converter</a></li>
      <li><a href="/tools/passport-photo-maker/">Passport Photo Maker</a></li>
      <li><a href="/tools/exif-remover/">EXIF Data Remover</a></li>
      <li><a href="/tools/image-info/">Image Dimensions Checker</a></li>
      <li><a href="/tools/compress-pdf/">PDF Compressor</a></li>
      <li><a href="/tools/merge-pdfs/">Merge PDF Files</a></li>
      <li><a href="/tools/pdf-to-jpg/">PDF to JPG Converter</a></li>
      <li><a href="/tools/images-to-pdf/">Images to PDF Converter</a></li>
      <li><a href="/tools/word-count/">Word Counter</a></li>
      <li><a href="/tools/lorem-ipsum/">Lorem Ipsum Generator</a></li>
      <li><a href="/tools/case-converter/">Text Case Converter</a></li>
      <li><a href="/tools/text-diff/">Text Difference Checker</a></li>
      <li><a href="/tools/json-formatter/">JSON Formatter &amp; Validator</a></li>
      <li><a href="/tools/base64/">Base64 Encoder / Decoder</a></li>
      <li><a href="/tools/social-sizes/">Social Media Image Sizes 2026</a></li>
      <li><a href="/tools/qr-code/">QR Code Generator</a></li>
      <li><a href="/tools/color-picker/">Color Picker HEX RGB HSL</a></li>
      <li><a href="/tools/password-generator/">Password Generator</a></li>
      <li><a href="/tools/image-to-text/">Image to Text OCR</a></li>
      <li><a href="/tools/gif-maker/">GIF Maker</a></li>
      <li><a href="/tools/image-watermark/">Image Watermark</a></li>
      <li><a href="/tools/color-palette/">Color Palette Generator</a></li>
      <li><a href="/tools/svg-to-png/">SVG to PNG Converter</a></li>
      <li><a href="/tools/favicon-generator/">Favicon Generator</a></li>
    </ul>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PixMidas",
    "url": "https://www.pixmidas.com/",
    "description": "Free browser-based tools for images, text, PDFs and more. No login, no upload, runs in your browser.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://www.pixmidas.com/?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "SiteNavigationElement",
    "name": [
      "Image Tools",
      "PDF Tools",
      "Text Tools",
      "Developer Tools",
      "Social Media Sizes"
    ],
    "url": [
      "https://www.pixmidas.com/categories/image-tools/",
      "https://www.pixmidas.com/categories/pdf-tools/",
      "https://www.pixmidas.com/categories/text-tools/",
      "https://www.pixmidas.com/categories/developer-tools/",
      "https://www.pixmidas.com/tools/social-sizes/"
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "PixMidas",
    "url": "https://www.pixmidas.com/",
    "logo": "https://www.pixmidas.com/favicon.svg",
    "description": "Free browser-based tools for images, text, PDFs and everyday digital tasks. No login, no upload required.",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer support",
      "email": "hello@pixmidas.com"
    },
    "sameAs": []
  }
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      /* ── PWA install prompt ────────────────────────────────────────────── */
      (function () {
        var pwaBtn     = document.getElementById('pwa-install-btn');
        var dismissBtn = document.getElementById('pwa-dismiss-btn');
        var popup      = document.getElementById('pwa-popup');
        var popupClose = document.getElementById('pwa-popup-close');
        var popupTitle = document.getElementById('pwa-popup-title');
        var popupSub   = document.getElementById('pwa-popup-subtitle');
        var popupSteps = document.getElementById('pwa-popup-steps');
        var overlay    = document.getElementById('pwa-overlay');
        if (!pwaBtn) return;

        if (localStorage.getItem('pwa-installed') || localStorage.getItem('pwa-dismissed')) return;

        var isSafari    = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
        var isIOS       = /iPhone|iPad|iPod/i.test(navigator.userAgent);
        var isMacSafari = isSafari && !isIOS;
        var isIOSSafari = isSafari && isIOS;
        var isMobile    = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);

        pwaBtn.textContent = isMobile ? '📲 Add to your home screen' : '💻 Add to your desktop';
        pwaBtn.style.display = 'inline-block';
        if (dismissBtn) dismissBtn.style.display = 'inline-block';

        function hideAll() {
          pwaBtn.style.display = 'none';
          if (dismissBtn) dismissBtn.style.display = 'none';
          closePopup();
        }

        function closePopup() {
          if (popup) popup.style.display = 'none';
          if (overlay) overlay.style.display = 'none';
        }

        function openPopup(title, subtitle, steps) {
          if (!popup || !popupTitle || !popupSub || !popupSteps) return;
          popupTitle.textContent = title;
          popupSub.textContent = subtitle;
          popupSteps.innerHTML = '';
          for (var i = 0; i < steps.length; i++) {
            var li = document.createElement('li');
            li.textContent = steps[i];
            popupSteps.appendChild(li);
          }
          popup.style.display = 'block';
          if (isMobile && overlay) overlay.style.display = 'block';
        }

        var deferredPrompt = window._pwaPrompt || null;
        window.addEventListener('beforeinstallprompt', function (e) {
          e.preventDefault();
          deferredPrompt = e;
          window._pwaPrompt = e;
        });

        pwaBtn.addEventListener('click', function () {
          if (deferredPrompt) {
            deferredPrompt.prompt();
            deferredPrompt.userChoice.then(function (result) {
              if (result.outcome === 'accepted') {
                localStorage.setItem('pwa-installed', 'true');
                hideAll();
              }
              deferredPrompt = null;
              window._pwaPrompt = null;
            });
          } else if (isIOSSafari) {
            if (popup && popup.style.display !== 'none') { closePopup(); return; }
            openPopup(
              'Add PixMidas to your home screen',
              'Follow these steps in Safari:',
              [
                'Tap the Share button ⬆️ at the bottom of your browser',
                'Scroll down and tap "Add to Home Screen"',
                'Tap "Add" in the top right corner',
                'PixMidas will appear on your home screen like an app ⚡'
              ]
            );
          } else if (isMacSafari) {
            if (popup && popup.style.display !== 'none') { closePopup(); return; }
            openPopup(
              'Add PixMidas to your desktop',
              'Follow these steps in Safari:',
              [
                'In the menu bar, click File',
                'Select "Add to Dock"',
                'Click "Add" to confirm',
                'PixMidas appears in your Dock and opens like an app ⚡'
              ]
            );
          }
        });

        if (dismissBtn) {
          dismissBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            localStorage.setItem('pwa-dismissed', 'true');
            hideAll();
          });
        }

        if (popupClose) {
          popupClose.addEventListener('click', function (e) {
            e.stopPropagation();
            closePopup();
          });
        }

        if (overlay) {
          overlay.addEventListener('click', closePopup);
        }

        window.addEventListener('appinstalled', function () {
          localStorage.setItem('pwa-installed', 'true');
          hideAll();
        });
      })();

      /* ── Random secondary CTA button ──────────────────────────────────── */
      var heroTryOptions = [
        { label: 'Try Image Compressor',   href: '/tools/compress-image/' },
        { label: 'Try Image Resizer',      href: '/tools/resize-image/' },
        { label: 'Try Background Remover', href: '/tools/background-remover/' },
        { label: 'Try HEIC to JPG',        href: '/tools/heic-to-jpg/' },
        { label: 'Try PDF Compressor',     href: '/tools/compress-pdf/' },
        { label: 'Try Merge PDFs',         href: '/tools/merge-pdfs/' },
        { label: 'Try QR Code Generator',  href: '/tools/qr-code/' },
        { label: 'Try Password Generator', href: '/tools/password-generator/' },
        { label: 'Try Word Counter',       href: '/tools/word-count/' },
      ];
      var pick = heroTryOptions[Math.floor(Math.random() * heroTryOptions.length)];
      var tryBtn = document.getElementById('hero-try-btn');
      if (tryBtn) { tryBtn.textContent = pick.label + ' →'; tryBtn.href = pick.href; }

      var searchInput = document.getElementById('tool-search');
      var buttons     = Array.from(document.querySelectorAll('.filter-btn'));
      var cards       = Array.from(document.querySelectorAll('.tool-card'));
      var noResults   = document.getElementById('no-results');

      if (!searchInput || !noResults || !cards.length) return;

      var activeCategory = 'All';

      /* ── Semantic alias map: user intent → tool slugs ─────────────────────
         These fire when the typed query *contains* the alias term anywhere.
         Checked after normal text matching so a tool can be surfaced even if
         the alias word doesn't appear in its name, description, or tags.     */
      var searchAliases = {
        /* Social platforms → Social Media Sizes */
        'instagram':        ['social-sizes'],
        'tiktok':           ['social-sizes'],
        'twitter':          ['social-sizes'],
        'facebook':         ['social-sizes'],
        'youtube':          ['social-sizes'],
        'linkedin':         ['social-sizes'],
        'snapchat':         ['social-sizes'],
        'pinterest':        ['social-sizes'],
        'reels':            ['social-sizes'],
        'stories':          ['social-sizes'],
        /* x is short so only match when followed by space or end */

        /* iPhone / Apple → HEIC to JPG */
        'iphone':           ['heic-to-jpg'],
        'ios':              ['heic-to-jpg'],
        'heif':             ['heic-to-jpg'],

        /* Compression intent */
        'shrink':           ['compress-image', 'compress-pdf'],
        'reduce':           ['compress-image', 'compress-pdf'],
        'optimize':         ['compress-image'],
        'optimise':         ['compress-image'],
        'smaller':          ['compress-image'],

        /* Background removal */
        'bg':               ['background-remover'],
        'remove bg':        ['background-remover'],
        'transparent':      ['background-remover'],
        'cutout':           ['background-remover'],
        'erase background': ['background-remover'],

        /* QR Code */
        'qr':               ['qr-code'],
        'barcode':          ['qr-code'],

        /* PDF merging */
        'combine':          ['merge-pdfs', 'images-to-pdf'],
        'join':             ['merge-pdfs'],
        'concatenate':      ['merge-pdfs'],
        'pdf merge':        ['merge-pdfs'],

        /* Password */
        'password':         ['password-generator'],
        'passphrase':       ['password-generator'],
        'strong':           ['password-generator'],

        /* Watermark */
        'watermark':        ['image-watermark'],
        'stamp':            ['image-watermark'],
        'copyright':        ['image-watermark'],

        /* GIF / animation */
        'gif':              ['gif-maker'],
        'animation':        ['gif-maker'],
        'animated':         ['gif-maker'],
        'frames':           ['gif-maker'],

        /* Passport photo */
        'passport':         ['passport-photo-maker'],
        'visa':             ['passport-photo-maker'],
        'id photo':         ['passport-photo-maker'],
        'document photo':   ['passport-photo-maker'],

        /* Cropping */
        'crop':             ['image-cropper'],
        'cut':              ['image-cropper'],
        'trim':             ['image-cropper'],
        'square':           ['image-cropper'],

        /* Favicon */
        'favicon':          ['favicon-generator'],
        'website icon':     ['favicon-generator'],
        'tab icon':         ['favicon-generator'],

        /* OCR / text extraction */
        'ocr':              ['image-to-text'],
        'extract text':     ['image-to-text'],
        'read text':        ['image-to-text'],
        'scan text':        ['image-to-text'],

        /* EXIF / privacy */
        'exif':             ['exif-remover'],
        'metadata':         ['exif-remover'],
        'gps':              ['exif-remover'],
        'location':         ['exif-remover'],
        'privacy':          ['exif-remover', 'password-generator'],

        /* Base64 */
        'encode':           ['base64'],
        'decode':           ['base64'],
        'binary':           ['base64'],

        /* JSON */
        'beautify':         ['json-formatter'],
        'minify':           ['json-formatter'],
        'validate':         ['json-formatter'],

        /* Color */
        'colour':           ['color-picker', 'color-palette'],
        'palette':          ['color-palette', 'color-picker'],
        'hex':              ['color-picker'],
        'rgb':              ['color-picker'],
        'hsl':              ['color-picker'],

        /* Image resizing */
        'resize':           ['resize-image'],
        'dimensions':       ['resize-image'],
        'width':            ['resize-image'],
        'height':           ['resize-image'],

        /* PDF compression */
        'compress pdf':     ['compress-pdf'],
        'shrink pdf':       ['compress-pdf'],
        'reduce pdf':       ['compress-pdf'],

        /* SVG */
        'vector':           ['svg-to-png'],
        'illustrator':      ['svg-to-png'],

        /* Lorem ipsum */
        'lorem':            ['lorem-ipsum'],
        'placeholder':      ['lorem-ipsum'],
        'dummy text':       ['lorem-ipsum'],
        'filler':           ['lorem-ipsum'],

        /* Word / character counting */
        'word count':       ['word-count'],
        'character count':  ['word-count'],
        'characters':       ['word-count'],
        'words':            ['word-count'],

        /* Case conversion */
        'uppercase':        ['case-converter'],
        'lowercase':        ['case-converter'],
        'capitalize':       ['case-converter'],
        'title case':       ['case-converter'],

        /* Text diff */
        'diff':             ['text-diff'],
        'compare':          ['text-diff'],
        'changes':          ['text-diff'],

        /* WebP */
        'google':           ['webp-to-jpg'],
        'google image':     ['webp-to-jpg'],
      };

      function normalize(s) {
        return String(s || '').toLowerCase().trim();
      }

      /* Set active category and update button states */
      function setCategory(cat) {
        activeCategory = cat;
        buttons.forEach(function (b) {
          b.setAttribute('aria-pressed', b.getAttribute('data-category') === cat ? 'true' : 'false');
        });
      }

      function filterTools() {
        var raw      = normalize(searchInput.value);
        var hasQuery = raw.length > 0;
        var words    = raw.split(/\s+/).filter(Boolean);

        /* Collect slugs that match via the alias map */
        var aliasedSlugs = Object.create(null);
        if (hasQuery) {
          var aliasKeys = Object.keys(searchAliases);
          for (var ai = 0; ai < aliasKeys.length; ai++) {
            var term = aliasKeys[ai];
            if (raw.indexOf(term) !== -1) {
              var targets = searchAliases[term];
              for (var ti = 0; ti < targets.length; ti++) {
                aliasedSlugs[targets[ti]] = true;
              }
            }
          }
        }

        var visible = 0;

        for (var ci = 0; ci < cards.length; ci++) {
          var card    = cards[ci];
          var href    = card.getAttribute('href') || '';
          /* extract "compress-image" from "/tools/compress-image/" */
          var slug    = href.replace(/^\/tools\//, '').replace(/\/$/, '');
          var cardCat = card.getAttribute('data-category') || '';
          var haystack = card.getAttribute('data-search') || '';

          /* When a query is active, ignore the category filter so users
             can find cross-category tools without resetting the tab first. */
          var catMatch;
          if (hasQuery) {
            catMatch = true;
          } else if (activeCategory === 'Popular') {
            catMatch = card.getAttribute('data-popular') === 'true';
          } else if (activeCategory === 'New') {
            catMatch = card.getAttribute('data-new') === 'true';
          } else {
            catMatch = activeCategory === 'All' || cardCat === activeCategory;
          }

          /* Normal substring match: every word must appear in haystack */
          var textMatch = words.length === 0 ||
            words.every(function (w) { return haystack.indexOf(w) !== -1; });

          /* Alias match: this slug was surfaced by the alias map */
          var aliasMatch = !!aliasedSlugs[slug];

          var show = catMatch && (textMatch || aliasMatch);
          card.style.display = show ? 'flex' : 'none';
          if (show) visible++;
        }

        noResults.style.display = visible === 0 ? 'block' : 'none';
      }

      /* ── Category buttons ─────────────────────────────────────────────── */
      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          /* Clicking a category clears any active search so the user
             sees the full category contents, not a filtered subset. */
          searchInput.value = '';
          setCategory(btn.getAttribute('data-category') || 'All');
          filterTools();
        });
      });

      /* ── Search input ─────────────────────────────────────────────────── */
      searchInput.addEventListener('input', filterTools);
      /* 'search' fires when user clicks the native ✕ clear button (Safari/Chrome) */
      searchInput.addEventListener('search', filterTools);

      /* ── Keyboard shortcuts ───────────────────────────────────────────── */
      document.addEventListener('keydown', function (e) {
        var tag = (document.activeElement ? document.activeElement.tagName : '').toUpperCase();
        if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA' && tag !== 'SELECT') {
          e.preventDefault();
          searchInput.focus();
          searchInput.select();
        }
        if (e.key === 'Escape' && document.activeElement === searchInput) {
          searchInput.value = '';
          filterTools();
          searchInput.blur();
        }
      });

      /* Initial render */
      filterTools();
    });
  </script>
</Layout>

