---
import Layout from '../layouts/Layout.astro';
import PromoBanner from '../components/PromoBanner.jsx';
import ShareSection from '../components/ShareSection.astro';

const tools = [
  { slug: 'compress-image', name: 'Image Compressor', description: 'Make image files smaller without losing quality.', icon: String.fromCodePoint(0x1F5DC)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'jpg', 'jpeg', 'png', 'webp', 'shrink', 'reduce', 'optimize', 'optimise', 'smaller', 'file size', 'upload', 'lighter', 'web', 'website speed', 'loading', 'performance', 'reduce size', 'make smaller'] },
  { slug: 'resize-image', name: 'Image Resizer', description: 'Resize photos to exact pixel dimensions.', icon: String.fromCodePoint(0x1F4D0), bg: '#e8f4fd', category: 'Image', popular: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'scale', 'dimensions', 'width', 'height', 'pixels', 'resolution', 'thumbnail', 'rescale', 'stretch', 'change size', 'make bigger', 'make smaller', 'fit', 'custom size'] },
  { slug: 'image-cropper', name: 'Image Cropper', description: 'Crop any image instantly. Draw a selection and download.', icon: String.fromCodePoint(0x2702)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'photo editing', 'trim', 'cut', 'frame', 'aspect ratio', 'portrait', 'landscape', 'square', 'selection', 'clip', 'cut out', 'remove border'] },
  { slug: 'convert-image', name: 'Image Converter', description: 'Convert PNG to JPG or JPG to PNG in one click.', icon: String.fromCodePoint(0x1F504), bg: '#e8f4fd', category: 'Image', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'format', 'jpg', 'jpeg', 'png', 'webp', 'gif', 'bmp', 'tiff', 'change format', 'transform', 'export', 'save as', 'file format'] },
  { slug: 'image-info', name: 'Image Info', description: 'Check the size, format and dimensions of any image.', icon: String.fromCodePoint(0x1F50D), bg: '#e8f4fd', category: 'Image', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'metadata', 'details', 'dimensions', 'resolution', 'megapixel', 'aspect ratio', 'file type', 'properties', 'inspect', 'dpi', 'camera info', 'check image', 'view details'] },
  { slug: 'webp-to-jpg', name: 'WebP to JPG', description: 'Convert WebP images to JPG instantly. Multiple files supported.', icon: String.fromCodePoint(0x1F5BC)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'format', 'convert', 'webp converter', 'compatibility', 'apple', 'ios', 'safari', 'chrome', 'browser', 'batch', 'multiple files'] },
  { slug: 'exif-remover', name: 'EXIF Data Remover', description: 'Strip hidden GPS, device info and timestamps from photos.', icon: String.fromCodePoint(0x1F6E1)+String.fromCodePoint(0xFE0F), bg: '#e8f4fd', category: 'Image', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'metadata', 'privacy', 'gps', 'location', 'coordinates', 'strip', 'clean', 'anonymous', 'secure', 'camera data', 'personal data', 'geolocation', 'remove metadata', 'sharing safely'] },
  { slug: 'background-remover', name: 'Background Remover', description: 'Remove the background from any image instantly using AI.', icon: String.fromCodePoint(0x1FA84), bg: '#e8f4fd', category: 'Image', popular: false, newTool: true, tags: ['photo', 'foto', 'picture', 'photography', 'editing', 'image editing', 'background', 'remove background', 'transparent', 'png', 'cutout', 'erase background', 'photo editing', 'ai', 'artificial intelligence', 'subject', 'portrait', 'product photo', 'studio', 'white background', 'silhouette', 'transparency'] },
  { slug: 'images-to-pdf', name: 'Images to PDF', description: 'Combine multiple photos into one PDF document.', icon: String.fromCodePoint(0x1F4C4), bg: '#fef3e8', category: 'PDF', popular: false, tags: ['photo', 'foto', 'picture', 'photography', 'creation', 'jpg', 'jpeg', 'png', 'combine', 'merge', 'create document', 'scans', 'album', 'portfolio', 'presentation', 'print', 'pages', 'book'] },
  { slug: 'pdf-to-jpg', name: 'PDF to JPG', description: 'Convert every PDF page to a JPG image instantly.', icon: String.fromCodePoint(0x1F4F8), bg: '#fef3e8', category: 'PDF', popular: false, tags: ['document', 'pages', 'extract', 'photo', 'picture', 'scan', 'view', 'render', 'creation', 'presentation', 'slide', 'export image', 'screenshot', 'page to image'] },
  { slug: 'merge-pdfs', name: 'Merge PDFs', description: 'Combine multiple PDF files into one document.', icon: String.fromCodePoint(0x1F4D1), bg: '#fef3e8', category: 'PDF', popular: false, tags: ['document', 'combine', 'join', 'concatenate', 'files', 'pages', 'stitch', 'creation', 'merge files', 'report', 'presentation', 'paperwork', 'combine documents'] },
  { slug: 'word-count', name: 'Word Counter', description: 'Count words, characters and paragraphs instantly.', icon: String.fromCodePoint(0x1F4DD), bg: '#e8fdf0', category: 'Text', popular: false, tags: ['writing', 'editing', 'article', 'essay', 'blog', 'letter', 'character count', 'reading time', 'sentences', 'paragraphs', 'typing', 'content', 'seo', 'word limit', 'copywriting', 'script', 'story', 'document'] },
  { slug: 'case-converter', name: 'Case Converter', description: 'Convert text to uppercase, lowercase, title case and more.', icon: String.fromCodePoint(0x1F521), bg: '#e8fdf0', category: 'Text', popular: false, tags: ['editing', 'writing', 'uppercase', 'lowercase', 'title case', 'camelcase', 'snake_case', 'kebab-case', 'capitalize', 'sentence case', 'programming', 'transform', 'formatting', 'fix caps', 'coding', 'change case'] },
  { slug: 'text-diff', name: 'Text Difference Checker', description: 'Compare two texts and see exactly what changed.', icon: String.fromCodePoint(0x1F50E), bg: '#e8fdf0', category: 'Text', popular: false, tags: ['editing', 'writing', 'compare', 'difference', 'delta', 'changes', 'version', 'before after', 'diff', 'code review', 'track changes', 'duplicate', 'programming', 'git', 'revision', 'find changes', 'document comparison'] },
  { slug: 'lorem-ipsum', name: 'Lorem Ipsum Generator', description: 'Generate placeholder text for layouts and mockups.', icon: String.fromCodePoint(0x1F4C3), bg: '#e8fdf0', category: 'Text', popular: false, tags: ['editing', 'writing', 'creation', 'design', 'web design', 'placeholder', 'dummy text', 'filler', 'mockup', 'sample', 'prototype', 'fake text', 'latin', 'ipsum', 'ui design', 'wireframe', 'template', 'content', 'paragraph generator'] },
  { slug: 'json-formatter', name: 'JSON Formatter', description: 'Format, validate and minify JSON data instantly.', icon: String.fromCodePoint(0x1F4CB), bg: '#ede8fd', category: 'Developer', popular: false, tags: ['developer', 'web', 'internet', 'online', 'programming', 'code', 'api', 'data', 'pretty print', 'validate', 'minify', 'syntax', 'javascript', 'object', 'lint', 'parse', 'backend', 'frontend', 'rest api', 'debugging', 'format code'] },
  { slug: 'base64', name: 'Base64 Encoder / Decoder', description: 'Encode text to Base64 or decode Base64 strings instantly.', icon: String.fromCodePoint(0x1F4BB), bg: '#ede8fd', category: 'Developer', popular: false, tags: ['developer', 'web', 'internet', 'online', 'programming', 'encode', 'decode', 'encoding', 'binary', 'string', 'data uri', 'api', 'cipher', 'obfuscate', 'web development', 'email', 'url safe', 'image embedding', 'encryption'] },
  { slug: 'social-sizes', name: 'Social Media Sizes', description: 'Find the correct image size for every social platform.', icon: String.fromCodePoint(0x1F4F1), bg: '#f0e8fd', category: 'Social', popular: false, tags: ['internet', 'web', 'online', 'network', 'media', 'photo', 'foto', 'picture', 'photography', 'design', 'creation', 'instagram', 'facebook', 'twitter', 'x', 'youtube', 'tiktok', 'linkedin', 'pinterest', 'snapchat', 'reddit', 'banner', 'cover photo', 'profile picture', 'post', 'social media', 'dimensions', 'thumbnail', 'story', 'reel', 'header', 'marketing', 'content creator', 'influencer', 'digital marketing', 'ads'] },
  { slug: 'qr-code', name: 'QR Code Generator', description: 'Create QR codes for any link, text or phone number.', icon: String.fromCodePoint(0x1F533), bg: '#fef9e3', category: 'Utility', popular: false, tags: ['internet', 'web', 'online', 'network', 'creation', 'link', 'url', 'scan', 'barcode', 'mobile', 'phone', 'camera', 'wifi', 'contact', 'vcard', 'share', 'digital', 'contactless', 'payment', 'restaurant menu', 'event', 'marketing', 'print', 'poster', 'business card'] },
  { slug: 'password-generator', name: 'Password Generator', description: 'Generate strong, secure passwords instantly.', icon: String.fromCodePoint(0x1F510), bg: '#fef9e3', category: 'Utility', popular: false, tags: ['internet', 'web', 'online', 'network', 'security', 'random', 'strong password', 'secure', 'credentials', 'login', 'account', 'passphrase', 'secret', 'cybersecurity', 'safe', 'protection', 'authentication', 'privacy', 'pin', 'encryption', 'hack proof'] },
  { slug: 'color-picker', name: 'Color Picker', description: 'Pick any color and get HEX, RGB and HSL values.', icon: String.fromCodePoint(0x1F3A8), bg: '#fef9e3', category: 'Utility', popular: false, tags: ['internet', 'web', 'online', 'editing', 'creation', 'media', 'design', 'colour', 'colour picker', 'hex', 'rgb', 'hsl', 'cmyk', 'palette', 'brand', 'css', 'web design', 'graphics', 'shade', 'tint', 'art', 'ui', 'ux', 'branding', 'logo', 'color scheme', 'colour scheme', 'color code', 'colour code', 'website color', 'marketing'] },
];

const categories = ['All', 'Image', 'PDF', 'Text', 'Developer', 'Social', 'Utility'];
---

<Layout
  title="Free Online Tools – Fast, Private & No Login Required"
  description="Free browser-based tools for images, text, PDFs and more. Compress images, resize photos, generate QR codes, count words and much more. No login, no upload, runs in your browser."
>
  <section class="hero">
    <h1 class="hero-title">Free tools<br/>that just work.</h1>
    <p class="hero-sub">Fast, free online tools with zero friction!</p>

    <div class="quick-links">
      <a href="/tools/compress-image/">Compress Image</a>
      <span>·</span>
      <a href="/tools/resize-image/">Resize Image</a>
      <span>·</span>
      <span><a href="/tools/qr-code/">QR Code</a> &amp; More</span>
    </div>

    <a href="#all-tools" class="hero-btn">See all tools ↓</a>
  </section>

  <div class="promo-wrap">
    <PromoBanner client:load />
  </div>

  <section id="all-tools" class="tools-section">
    <div class="filter-bar-wrap">
      <div class="filter-bar">
        {categories.map((cat) => (
          <button class="filter-btn" data-category={cat} aria-pressed={cat === 'All' ? 'true' : 'false'}>
            {cat}
          </button>
        ))}
      </div>
    </div>

    <div class="search-wrap">
      <svg class="search-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
        <circle cx="7.5" cy="7.5" r="5" stroke="currentColor" stroke-width="1.6"/>
        <path d="M11.5 11.5L15.5 15.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      <input
        type="search"
        id="tool-search"
        class="search-input"
        placeholder="Search tools… (e.g. compress, PDF, QR)"
        aria-label="Search tools"
        autocomplete="off"
        spellcheck="false"
      />
      <span class="search-kbd" aria-hidden="true">/</span>
    </div>

    <div class="tools-grid">
      {tools.map((tool) => (
        <a
          class="tool-card"
          href={"/tools/" + tool.slug + "/"}
          data-category={tool.category}
          data-search={(tool.name + ' ' + tool.description + ' ' + tool.category + ' ' + tool.tags.join(' ')).toLowerCase()}
        >
          <div class="tool-icon-wrap" data-bg={tool.bg}>
            <span class="tool-icon">{tool.icon}</span>
          </div>
          <div class="tool-body">
            <div class="tool-name-row">
              <h3 class="tool-name">{tool.name}</h3>
              {tool.popular && <span class="badge">Popular</span>}
              {tool.newTool && <span class="badge badge-new">New</span>}
            </div>
            <p class="tool-desc">{tool.description}</p>
          </div>
          <span class="tool-arrow">→</span>
        </a>
      ))}
    </div>

    <p class="no-results" id="no-results" style="display:none">
      No tools found for that. Try something else.
    </p>
  </section>

  <div class="promo-wrap promo-bottom">
    <PromoBanner client:load />
  </div>

  <section class="trust-section">
    <div class="trust-grid">
      <div class="trust-item">
        <span class="trust-icon">🔒</span>
        <div>
          <strong>Private by design</strong>
          <p>Many tools run locally in your browser. Your files stay on your device.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">⚡</span>
        <div>
          <strong>Fast and simple</strong>
          <p>No heavy software or confusing steps. Results in seconds.</p>
        </div>
      </div>
      <div class="trust-item">
        <span class="trust-icon">🆓</span>
        <div>
          <strong>Always free</strong>
          <p>No account needed. No payment. No hidden limits.</p>
        </div>
      </div>
    </div>
  </section>

  <ShareSection pageUrl="https://www.pixmidas.com/" />

  <section class="seo-content">
    <h2>Free Online Tools for Images, Text, PDFs and More</h2>
    <p>PixMidas is a growing collection of free browser-based tools built for everyday digital tasks. Compress and resize images, convert between formats, generate QR codes, count words, merge PDFs, pick colors, compare text differences and more — all without installing software, creating an account or uploading your files to a server.</p>
    <p>Privacy is a first principle here. Most tools process your files entirely on your device using browser APIs. Your images, documents and text stay on your machine. Nothing is transmitted, logged or stored. Fast, simple and private by design.</p>
    <h3>Image Tools</h3>
    <p>Compress JPG, PNG and WebP images to reduce file size without visible quality loss. Resize photos to exact pixel dimensions. Crop images by drawing a selection. Convert between PNG, JPG and WebP formats. Check image dimensions and file size. Convert WebP images to JPG for maximum compatibility.</p>
    <h3>PDF Tools</h3>
    <p>Convert PDF pages to JPG images. Combine multiple images into a single PDF. Merge several PDF files into one document. All PDF processing runs in the browser — no cloud upload required.</p>
    <h3>Text Tools</h3>
    <p>Count words, characters and sentences in real time. Convert text between uppercase, lowercase, title case, camelCase, snake_case and kebab-case. Compare two texts side by side and highlight every difference. Generate lorem ipsum placeholder text for layouts and mockups.</p>
    <h3>Developer Tools</h3>
    <p>Format and validate JSON data. Encode text to Base64 or decode Base64 strings. Generate QR codes for any URL, text, email or phone number. Create strong random passwords. Pick colors and get HEX, RGB and HSL codes.</p>
    <h3>All Free Tools on PixMidas</h3>
    <ul class="seo-list">
      <li><a href="/tools/compress-image/">Free Image Compressor</a></li>
      <li><a href="/tools/resize-image/">Online Image Resizer</a></li>
      <li><a href="/tools/image-cropper/">Free Image Cropper</a></li>
      <li><a href="/tools/convert-image/">PNG to JPG Converter</a></li>
      <li><a href="/tools/image-info/">Image Dimensions Checker</a></li>
      <li><a href="/tools/webp-to-jpg/">WebP to JPG Converter</a></li>
      <li><a href="/tools/pdf-to-jpg/">PDF to JPG Converter</a></li>
      <li><a href="/tools/images-to-pdf/">Images to PDF Converter</a></li>
      <li><a href="/tools/merge-pdfs/">Merge PDF Files</a></li>
      <li><a href="/tools/word-count/">Word Counter Tool</a></li>
      <li><a href="/tools/case-converter/">Text Case Converter</a></li>
      <li><a href="/tools/text-diff/">Text Difference Checker</a></li>
      <li><a href="/tools/lorem-ipsum/">Lorem Ipsum Generator</a></li>
      <li><a href="/tools/qr-code/">Free QR Code Generator</a></li>
      <li><a href="/tools/password-generator/">Password Generator</a></li>
      <li><a href="/tools/color-picker/">Color Picker HEX RGB HSL</a></li>
      <li><a href="/tools/social-sizes/">Social Media Image Sizes 2025</a></li>
      <li><a href="/tools/base64/">Base64 Encoder / Decoder</a></li>
      <li><a href="/tools/json-formatter/">JSON Formatter &amp; Validator</a></li>
      <li><a href="/tools/exif-remover/">EXIF Data Remover</a></li>
    </ul>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "PixMidas",
    "url": "https://www.pixmidas.com/",
    "description": "Free browser-based tools for images, text, PDFs and more. No login, no upload, runs in your browser.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.pixmidas.com/#all-tools",
      "query-input": "required name=search_term_string"
    }
  }
  </script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('.tool-icon-wrap').forEach(function (wrap) {
        var bg = wrap.getAttribute('data-bg');
        if (bg) wrap.style.background = bg;
      });

      var searchInput = document.getElementById('tool-search');
      var buttons = Array.from(document.querySelectorAll('.filter-btn'));
      var cards = Array.from(document.querySelectorAll('.tool-card'));
      var noResults = document.getElementById('no-results');
      var activeCategory = 'All';

      if (!searchInput || !noResults || !cards.length) return;

      function normalize(text) {
        return String(text || '').toLowerCase().trim();
      }

      function filterTools() {
        var query = normalize(searchInput.value);
        var words = query.split(/\s+/).filter(Boolean);
        var visible = 0;

        cards.forEach(function (card) {
          var catMatch =
            activeCategory === 'All' ||
            card.getAttribute('data-category') === activeCategory;

          var haystack = card.getAttribute('data-search') || '';

          var searchMatch =
            words.length === 0 ||
            words.every(function (word) {
              return haystack.indexOf(word) !== -1;
            });

          var show = catMatch && searchMatch;

          card.style.display = show ? 'flex' : 'none';

          if (show) visible++;
        });

        noResults.style.display = visible === 0 ? 'block' : 'none';
      }

      buttons.forEach(function (btn) {
        btn.addEventListener('click', function () {
          activeCategory = btn.getAttribute('data-category') || 'All';

          buttons.forEach(function (button) {
            button.setAttribute('aria-pressed', 'false');
          });

          btn.setAttribute('aria-pressed', 'true');
          filterTools();
        });
      });

      searchInput.addEventListener('input', filterTools);
      searchInput.addEventListener('search', filterTools);
      searchInput.addEventListener('keyup', filterTools);

      document.addEventListener('keydown', function (e) {
        var activeElement = document.activeElement;
        var tag = activeElement && activeElement.tagName
          ? activeElement.tagName.toUpperCase()
          : '';

        if (
          e.key === '/' &&
          tag !== 'INPUT' &&
          tag !== 'TEXTAREA' &&
          tag !== 'SELECT'
        ) {
          e.preventDefault();
          searchInput.focus();
        }

        if (e.key === 'Escape' && document.activeElement === searchInput) {
          searchInput.value = '';
          filterTools();
          searchInput.blur();
        }
      });

      filterTools();
    });
  </script>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 72px 0 56px;
  }

  .hero-title {
    font-size: clamp(52px, 9.6vw, 98px);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.04;
    margin-bottom: 20px;
    color: var(--text);
  }

  .hero-sub {
    font-size: clamp(17px, 2.4vw, 21px);
    color: var(--text-muted);
    line-height: 1.55;
    max-width: 500px;
    margin: 0 auto 24px;
  }

  .quick-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 28px;
    font-size: 15px;
  }

  .quick-links a {
    color: var(--text);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.15s;
  }

  .quick-links a:hover {
    color: var(--accent);
  }

  .quick-links span {
    color: var(--text-muted);
    font-weight: 400;
    font-size: 1em;
  }

  .hero-btn {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 17px;
    font-weight: 700;
    padding: 16px 36px;
    border-radius: 999px;
    transition: background 0.15s, transform 0.15s;
    box-shadow: 0 8px 24px rgba(0,113,227,0.22);
  }

  .hero-btn:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
  }

  .promo-wrap {
    width: 100%;
    margin: 36px 0 48px;
  }

  .promo-bottom {
    margin-top: 48px;
    margin-bottom: 0;
  }

  .tools-section {
    scroll-margin-top: 80px;
  }

  .search-wrap {
    position: relative;
    margin-bottom: 16px;
  }

  .search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-light);
    pointer-events: none;
    flex-shrink: 0;
  }

  .search-input {
    width: 100%;
    padding: 14px 48px 14px 42px;
    font-size: 16px;
    font-family: inherit;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow-sm);
    -webkit-appearance: none;
    appearance: none;
  }

  .search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(0, 113, 227, 0.1);
  }

  .search-input::placeholder {
    color: var(--text-light);
  }

  .search-input::-webkit-search-decoration,
  .search-input::-webkit-search-cancel-button,
  .search-input::-webkit-search-results-button,
  .search-input::-webkit-search-results-decoration {
    display: none;
  }

  .search-kbd {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-light);
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 2px 7px;
    font-family: inherit;
    pointer-events: none;
    transition: opacity 0.12s;
    line-height: 1.6;
  }

  .search-input:focus ~ .search-kbd {
    opacity: 0;
  }

  .filter-bar-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: 12px;
  }

  .filter-bar-wrap::-webkit-scrollbar {
    display: none;
  }

  .filter-bar {
    display: flex;
    gap: 8px;
    width: max-content;
    padding-bottom: 4px;
  }

  .filter-btn {
    padding: 10px 20px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface-2);
    color: var(--text-muted);
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
    white-space: nowrap;
    min-height: 44px;
  }

  .filter-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .filter-btn[aria-pressed="true"] {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .cat-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 20px;
  }

  .cat-link {
    font-size: 13px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .cat-link:hover {
    color: var(--accent);
  }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
