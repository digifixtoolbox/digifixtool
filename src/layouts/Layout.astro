---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact PixMidas"
  description="Get in touch with PixMidas. We'd love to hear your feedback, suggestions or questions."
>
  <div class="page">
    <h1>Contact Us</h1>
    <p class="lead">Have a question, suggestion or feedback? We would love to hear from you.</p>

    <section class="contact-box">
      <div class="contact-item">
        <span class="contact-icon">✉️</span>
        <div>
          <strong>Email us</strong>
          <p>For questions, feedback or tool suggestions:</p>
          <a href="mailto:hello@pixmidas.com" class="email-link">hello@pixmidas.com</a>
        </div>
      </div>
      <div class="contact-item">
        <span class="contact-icon">⚡</span>
        <div>
          <strong>Response time</strong>
          <p>We typically respond within 1-2 business days.</p>
        </div>
      </div>
      <div class="contact-item">
        <span class="contact-icon">🛠️</span>
        <div>
          <strong>Suggest a tool</strong>
          <p>Have an idea for a new tool? Send us an email and we will consider adding it.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style>
  .page {
    max-width: 640px;
    margin: 0 auto;
    padding: 20px 0 80px;
  }

  h1 {
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .lead {
    font-size: 18px;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 48px;
  }

  .contact-box {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    background: var(--surface-2);
    border-radius: var(--radius);
    padding: 24px;
  }

  .contact-icon {
    font-size: 32px;
    flex-shrink: 0;
  }

  .contact-item strong {
    display: block;
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--text);
  }

  .contact-item p {
    font-size: 14px;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  .email-link {
    display: inline-block;
    margin-top: 8px;
    font-size: 16px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
  }

  .email-link:hover {
    text-decoration: underline;
  }
</style>